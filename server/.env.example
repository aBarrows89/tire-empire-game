PORT=3000
DATABASE_URL=postgresql://localhost:5432/tire_empire
TICK_MS=60000
NODE_ENV=development
CORS_ORIGIN=*
STORAGE=memory

# Admin user Firebase UIDs (comma-separated)
ADMIN_UIDS=your-firebase-uid
ADMIN_KEY=your-admin-key

# Firebase Admin SDK (server-side auth)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase Web SDK (admin panel Google Sign-In)
FIREBASE_API_KEY=

# Dev mode: allow X-Player-Id header bypass (never enable in production)
ALLOW_DEV_AUTH=true

# Reddit API (for Reddit Scout — used to identify requests to Reddit's public API)
REDDIT_USER_AGENT=nodejs:tire-empire-admin:v1.0.0 (by /u/YourRedditUsername)

# AdMob (rewarded ads — replace with real IDs from admob.google.com)
ADMOB_APP_ID_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY
# ADMOB_APP_ID_IOS=ca-app-pub-XXXXXXXXXXXXXXXX~ZZZZZZZZZZ
# ADMOB_SSVC_SECRET=  # For server-side verification (future)
